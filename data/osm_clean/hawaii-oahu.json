  {
    "name": "Mahi Wreck",
    "lat": 21.42,
    "lon": -158.19,
    "depth": 27,
    "site_type": "wreck",
    "entry_type": "boat",
    "difficulty": "Intermediate",
    "tags": {
      "source": "curated",
      "addedBy": "gap_fill",
      "validated": "true",
      "validation_source": "wikipedia.org,oahudiving.com,banzaidivershawaii.com",
      "last_qa_date": "2026-06-06",
      "description": "Formerly USS Scrimmage (AM-297), Admirable-class minesweeper, 184 ft 6 in (56.24 m), commissioned 1944. Served WWII (six battle stars), decommissioned 1946, later served as research vessel MS Mahi for University of Hawaii. Sold 1982 to Dacor Scuba Diving and sunk as artificial reef off Waianae. Main deck at 65 ft, bottom at 90 ft. Famous for white-spotted eagle rays."
    }
  },
  {
